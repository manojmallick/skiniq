# Perfect Corp YouCam API
YOUCAM_API_KEY=            # From yce.perfectcorp.com → API Keys (redeem: Pegasus1000)
YOUCAM_BASE_URL=https://yce-us.perfectcorp.com   # Verify from docs.perfectcorp.com

# Google Gemini API (for product recommendations)
GEMINI_API_KEY=            # From aistudio.google.com/app/apikey
GEMINI_MODEL=gemini-1.5-flash

# App
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# PRIVACY — GDPR Compliance
# Never log user images. Never store them beyond the API call.
STORE_USER_IMAGES=false    # Always false
